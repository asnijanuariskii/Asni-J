{
  "enabled": true,
  "name": "Deploy to VM",
  "description": "Manual button to deploy latest code to cloud VM. SSHs into VM, pulls latest code, rebuilds if needed, restarts containers, and runs health checks.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "SSH into VM, pull latest code, rebuild if needed, restart containers, verify services, health check."
  }
}