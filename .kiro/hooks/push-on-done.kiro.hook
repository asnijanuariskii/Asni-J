{
  "enabled": true,
  "name": "Push on Done",
  "description": "Auto-commit and push all changes to GitHub when the agent stops.",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A && (git diff --cached --quiet || (git commit -m auto-kiro-update && git push origin master))"
  }
}